<div class="fixed inset-0 bg-[#07060A] z-0 overflow-hidden">
  <!-- Dynamic Glow Background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[150%] aspect-square bg-gradient-radial from-indigo-500/10 via-transparent to-transparent animate-slow-pulse"></div>
  <div class="absolute -top-40 -left-40 w-96 h-96 bg-purple-500/5 blur-[120px] rounded-full"></div>
  <div class="absolute -bottom-40 -right-40 w-96 h-96 bg-indigo-500/5 blur-[120px] rounded-full"></div>
</div>

<div class="relative z-10 pt-10 pb-20 flex flex-col min-h-screen">
  <!-- Header -->
  <header class="flex items-center justify-between px-2 mb-12">
    <%= link_to prototype_home_path, class: "w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-white" do %>
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
    <% end %>
    <div class="flex items-center gap-2 px-4 py-1.5 <%= @is_club_member ? 'bg-rose-600/20 border-rose-500/30' : 'bg-indigo-600/20 border-indigo-500/30' %> rounded-full border">
       <div class="w-1.5 h-1.5 rounded-full <%= @is_club_member ? 'bg-rose-500' : 'bg-indigo-500' %> animate-pulse"></div>
       <span class="text-[10px] font-black <%= @is_club_member ? 'text-rose-500' : 'text-indigo-500' %> uppercase tracking-widest">
         <%= @is_club_member ? 'Live Now' : 'Sneak Peek' %>
       </span>
    </div>
    <div class="w-10"></div> <!-- Placeholder for symmetry -->
  </header>

  <!-- 2. Collective Status Dashboard -->
  <section class="px-6 space-y-4 mb-10">
    <div class="grid grid-cols-2 gap-3">
      <!-- Today's Avg Achievement -->
      <div class="app-glass-card p-5 bg-gradient-to-br from-rose-500/10 to-transparent border-rose-500/20 rounded-[32px] flex flex-col justify-between">
        <div>
          <p class="text-[9px] font-black text-rose-400 uppercase tracking-widest leading-none mb-1">오늘의 활력</p>
          <h4 class="text-xs font-bold text-slate-300">오늘 평균 성취도</h4>
        </div>
        <div class="flex items-baseline gap-1.5 mt-4">
          <span class="text-3xl font-black text-white tabular-nums"><%= @club_today_avg_achievement %>%</span>
          <span class="text-[9px] font-black text-rose-500 animate-pulse">AVG</span>
        </div>
      </div>
      
      <!-- Season Avg Achievement -->
      <div class="app-glass-card p-5 bg-gradient-to-br from-indigo-500/10 to-transparent border-indigo-500/20 rounded-[32px] flex flex-col justify-between">
        <div>
          <p class="text-[9px] font-black text-indigo-400 uppercase tracking-widest leading-none mb-1">시즌 성적</p>
          <h4 class="text-xs font-bold text-slate-300">시즌 누적 성취도</h4>
        </div>
        <div class="flex items-baseline gap-1 mt-4">
          <span class="text-3xl font-black text-white tabular-nums"><%= @club_season_avg_achievement %>%</span>
          <span class="text-[9px] font-bold text-slate-500 uppercase tracking-tighter">AVG</span>
        </div>
      </div>
    </div>

    <!-- Official Notice -->
    <% if @club_announcements.any? %>
      <% announcement = @club_announcements.first %>
      <button type="button" 
              onclick="document.getElementById('announcement-modal').classList.remove('hidden')"
              class="w-full text-left app-glass-card p-4 bg-indigo-500/10 border-indigo-500/20 rounded-[24px] flex items-center gap-4 active:scale-[0.98] transition-all">
        <div class="w-10 h-10 rounded-xl bg-indigo-600/20 flex items-center justify-center text-lg shadow-inner shrink-0">📢</div>
        <div class="flex-1 min-w-0">
          <p class="text-[9px] font-black text-indigo-400 uppercase tracking-widest mb-0.5">공지사항</p>
          <p class="text-xs font-bold text-white truncate"><%= announcement.title %></p>
        </div>
        <svg class="w-4 h-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      </button>

      <!-- Announcement Detail Modal -->
      <div id="announcement-modal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-0 sm:p-4">
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="this.parentElement.classList.add('hidden')"></div>
        <div class="relative w-full max-w-lg bg-[#0C0B12] rounded-t-[40px] sm:rounded-[40px] border-t sm:border border-white/10 flex flex-col overflow-hidden animate-slide-up">
          <div class="p-8 space-y-6">
            <div class="flex justify-between items-start">
              <div class="space-y-1">
                <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest">공식 공지</p>
                <h4 class="text-xl font-black text-white leading-tight"><%= announcement.title %></h4>
                <p class="text-[10px] font-bold text-slate-500"><%= announcement.created_at.strftime('%Y.%m.%d %H:%M') %></p>
              </div>
              <button onclick="this.closest('#announcement-modal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400">✕</button>
            </div>
            <div class="h-px w-full bg-white/5"></div>
            <div class="text-sm font-medium text-slate-300 leading-relaxed min-h-[200px] whitespace-pre-wrap text-left"><%= announcement.content.presence || "상세 공지 내용이 등록되지 않았습니다." %></div>
            <button onclick="this.closest('#announcement-modal').classList.add('hidden')" class="w-full py-4 rounded-2xl bg-indigo-600 text-white font-black text-sm active:scale-95 transition-all">확인했습니다</button>
          </div>
        </div>
      </div>
    <% end %>
  </section>

  <!-- 3. Current Focus Status (Simple) -->
  <main class="flex-1 flex flex-col items-center justify-center text-center space-y-12 px-4 py-8">
    <!-- Message -->

    <!-- Message -->
    <div class="space-y-3 px-6 text-center max-w-sm mx-auto">
      <h3 class="text-xl md:text-2xl font-black text-white leading-tight">성장의 에너지가 모이는 곳</h3>
      <p class="text-[11px] font-bold text-slate-400 leading-relaxed">
        지금 이 순간, 라운지에서는 루파 멤버들이<br/>
        서로의 열정을 나누며 함께 성장하고 있습니다.
      </p>
    </div>
  </main>

  <!-- 4. Integrated Experience Rooms -->
  <section class="mt-12 px-6 space-y-4">
    <div class="flex items-center justify-between px-1 mb-2">
      <h4 class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">프리미엄 룸</h4>
      <span class="w-12 h-px bg-white/5"></span>
    </div>

    <!-- Live Room Card -->
    <div class="app-glass-card p-5 bg-white/5 border-white/10 rounded-[32px] group <%= 'opacity-60' unless @current_club&.live_room_active %>">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-indigo-500/20 flex items-center justify-center text-xl">📹</div>
          <div>
            <p class="text-[10px] font-black text-indigo-400 uppercase tracking-widest leading-none mb-1">라이브 룸</p>
            <h4 class="text-sm font-black text-white"><%= @current_club&.live_room_title.presence || "온라인 공동 몰입 세션" %></h4>
          </div>
        </div>
        <% if @current_club&.live_room_active && @current_club&.zoom_link.present? %>
          <div class="px-2 py-0.5 bg-rose-500 text-white text-[8px] font-black rounded animate-pulse">ON AIR</div>
        <% end %>
      </div>
      
      <% if @current_club&.live_room_active && @current_club&.zoom_link.present? %>
        <a href="<%= @current_club.zoom_link %>" target="_blank" class="w-full py-4 rounded-2xl bg-white text-black font-black text-sm flex items-center justify-center gap-2 active:scale-95 transition-all">
          <%= @current_club.live_room_button_text.presence || "라이브 입장하기" %>
        </a>
      <% else %>
        <div class="w-full py-4 rounded-2xl bg-white/5 text-slate-500 font-black text-sm text-center border border-white/5 italic">현재 라이브 세션 준비 중입니다</div>
      <% end %>
    </div>

    <!-- Lecture Room Card -->
    <div class="app-glass-card p-5 bg-white/5 border-white/10 rounded-[32px] group <%= 'opacity-60' unless @current_club&.lecture_room_active %>">
      <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center text-xl">🎓</div>
          <div>
            <p class="text-[10px] font-black text-purple-400 uppercase tracking-widest leading-none mb-1">강의실</p>
            <h4 class="text-sm font-black text-white"><%= @current_club&.lecture_room_title.presence || "스페셜 인사이트 강의실" %></h4>
          </div>
        </div>
      </div>
      
      <div class="text-[11px] font-medium text-slate-400 mb-5 leading-relaxed whitespace-pre-wrap break-all text-left"><%= @current_club&.lecture_room_description.presence || "명예의 전당 멤버들을 위한 독점 인사이트 강의가 진행됩니다." %></div>
      
      <% if @current_club&.lecture_room_active && @current_club&.special_lecture_link.present? %>
        <a href="<%= @current_club.special_lecture_link %>" target="_blank" class="w-full py-4 rounded-2xl bg-indigo-600 text-white font-black text-sm flex items-center justify-center gap-2 active:scale-95 transition-all">강의실 입장하기</a>
      <% else %>
        <div class="w-full py-4 rounded-2xl bg-white/5 text-slate-500 font-black text-sm text-center border border-white/5 italic">현재 강의 시간이 아닙니다</div>
      <% end %>
    </div>
  </section>

  <!-- 5. Hall of Fame (Club Members List) -->
  <section class="mt-12 px-6 space-y-6">
    <div class="flex items-center justify-between px-1">
      <h4 class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">명예의 전당</h4>
      <p class="text-[9px] font-bold text-indigo-400"><%= @club_total_members_count %>명의 루파들이 함께하는 중</p>
    </div>

    <div class="grid grid-cols-2 gap-3 transition-all">
      <% @confirmed_members.each_with_index do |member, index| %>
        <%= link_to prototype_user_card_path(member.user), 
                    data: { turbo_frame: "user-profile-modal-frame" },
                    class: "app-glass-card p-3 bg-white/[0.02] border-white/5 rounded-2xl flex items-center gap-3 hover:bg-white/5 active:scale-95 transition-all #{'hidden extra-member' if index >= 10}" do %>
          <div class="w-8 h-8 rounded-lg overflow-hidden shrink-0 border border-white/10">
            <img src="<%= member.user.profile_image %>" class="w-full h-full object-cover">
          </div>
          <div class="min-w-0">
            <p class="text-[11px] font-black text-white truncate"><%= member.user.nickname %></p>
            <p class="text-[9px] font-bold text-slate-500">Lv.<%= member.user.level %></p>
          </div>
        <% end %>
      <% end %>
      
      <% if @confirmed_members.count > 10 %>
        <button type="button" onclick="document.querySelectorAll('.extra-member').forEach(el => el.classList.remove('hidden')); this.remove();" class="app-glass-card p-3 bg-indigo-500/5 border border-indigo-500/10 rounded-2xl flex items-center justify-center col-span-2 sm:col-span-1 active:scale-95 transition-all cursor-pointer hover:bg-indigo-500/10">
          <p class="text-[9px] font-black text-indigo-400">+ <%= @confirmed_members.count - 10 %>명 더 보기</p>
        </button>
      <% end %>
    </div>
  </section>

  <!-- 6. Support & Communication -->
  <section class="mt-12 px-6 pb-24 space-y-4">
    <div class="flex items-center justify-between px-1 mb-2">
      <h4 class="text-[10px] font-black text-slate-500 uppercase tracking-[0.2em]">고객 지원 & 링크</h4>
      <span class="w-12 h-px bg-white/5"></span>
    </div>

    <!-- KakaoTalk Group Chat -->
    <a href="https://open.kakao.com/o/gt1WHswh" target="_blank" class="app-glass-card p-5 bg-[#FEE500]/5 border-[#FEE500]/20 rounded-[32px] flex items-center justify-between group active:scale-[0.98] transition-all">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl bg-[#FEE500] flex items-center justify-center text-2xl shadow-lg shadow-yellow-900/20">💬</div>
        <div>
          <p class="text-[10px] font-black text-[#FEE500] uppercase tracking-widest leading-none mb-1">공식 채팅방</p>
          <h4 class="text-sm font-black text-white">클럽 실시간 단톡방</h4>
          <p class="text-[9px] font-bold text-slate-500 mt-0.5">멤버들과의 실시간 소통 및 공지</p>
        </div>
      </div>
      <svg class="w-5 h-5 text-slate-600 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
    </a>
  </section>

<!-- User Profile Modal Frame -->
  <turbo-frame id="user-profile-modal-frame"></turbo-frame>
</div>

<% content_for :modal_container do %>
  <% if @march_gathering && !@already_joined_gathering %>
    <div id="march-gathering-modal" class="hidden fixed inset-0 z-[50000] flex items-center justify-center p-6 bg-black/80 backdrop-blur-sm">
      <div onclick="dismissGatheringModal()" class="absolute inset-0"></div>
      <div class="relative w-full max-w-sm app-glass-card border-white/20 p-8 flex flex-col items-center text-center space-y-6 animate-badge-celebration-pop bg-[#16151D]">
         <button onclick="dismissGatheringModal()" class="absolute right-4 top-4 text-slate-500 hover:text-white p-2 z-10 bg-[#16151D]/50 rounded-full backdrop-blur">✕</button>
         
         <div class="w-20 h-20 bg-emerald-500/20 rounded-[28px] flex items-center justify-center text-4xl shadow-2xl shadow-emerald-500/40 mb-2 border border-emerald-500/30">🍻</div>
         
         <div class="space-y-4 w-full">
           <h3 class="text-xl font-black text-white"><%= @march_gathering.title %></h3>
           <p class="text-[13px] font-bold text-slate-300 leading-relaxed break-keep">
             드디어 오프라인 모임의 모집이 시작되었습니다!<br/><br/>
             일정: <%= @march_gathering.start_date&.strftime('%m.%d') %> <%= @march_gathering.meeting_time&.strftime('%H:%M') %><br/>
             장소: <%= @march_gathering.place_name.presence || "판교 고등동 일상찻집" %>
           </p>
         </div>

         <div class="w-full space-y-3 pt-4">
           <%= link_to challenge_path(@march_gathering, source: "prototype"), 
               class: "block w-full py-4 bg-emerald-500 text-white font-black rounded-2xl active:scale-95 transition-all shadow-lg shadow-emerald-500/30",
               onclick: "dismissGatheringModal(true)" do %>
             지금 바로 신청하기
           <% end %>
           <button onclick="dismissGatheringModal()" class="text-xs font-bold text-slate-500 hover:text-white py-2">
             나중에 할게요
           </button>
         </div>
      </div>
    </div>

    <script>
      function dismissGatheringModal(apply = false) {
        document.getElementById('march-gathering-modal').classList.add('hidden');
        if (!apply) {
          const date = new Date();
          date.setHours(23, 59, 59, 999);
          document.cookie = "march_gathering_seen_v1=true; expires=" + date.toUTCString() + "; path=/";
        }
      }

      document.addEventListener('DOMContentLoaded', () => {
        setTimeout(() => {
          const cookie = document.cookie.split('; ').find(row => row.startsWith('march_gathering_seen_v1='));
          if (!cookie) {
            document.getElementById('march-gathering-modal')?.classList.remove('hidden');
          }
        }, 800);
      });
    </script>
  <% end %>
<% end %>

<style>
  @keyframes slow-pulse {
    0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.1; }
    50% { transform: translate(-50%, -50%) scale(1.1); opacity: 0.2; }
  }
  .animate-slow-pulse {
    animation: slow-pulse 8s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  .animate-float {
    animation: float 4s ease-in-out infinite;
  }
  @keyframes orbit-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
  @keyframes orbit-spin-reverse {
    from { transform: rotate(0deg); }
    to { transform: rotate(-360deg); }
  }
  .animate-orbit-1 { animation: orbit-spin 45s linear infinite; }
  .animate-orbit-2 { animation: orbit-spin 70s linear infinite reverse; }
  .animate-orbit-3 { animation: orbit-spin 60s linear infinite; }
</style>
