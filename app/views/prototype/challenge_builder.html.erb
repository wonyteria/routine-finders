                <div class="space-y-1">
                  <p class="text-[9px] font-black text-slate-600 uppercase tracking-widest">Recruitment</p>
                  <p id="review_recruitment" class="text-[10px] font-black text-emerald-400">~ 2026.01.19</p>
                </div>
              </div>
           </div>

           <!-- Review: Mission Goals -->
           <div class="bg-white/5 rounded-[32px] p-6 space-y-3 border border-white/5">
             <p class="text-xs font-black text-indigo-400 uppercase tracking-wider">Daily Mission</p>
