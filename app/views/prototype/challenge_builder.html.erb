                </button>

                <%= f.hidden_field :application_questions, value: f.object.application_questions.to_json, id: "h_application_questions" %>
                <%= f.hidden_field :requires_application_message, id: "h_requires_msg", value: "false" %>
              </div>
           </div>

           <div class="space-y-3">
             <div class="p-5 bg-white/5 border border-white/5 rounded-2xl flex items-start gap-3">
                <span class="text-xl">📋</span>
                <div class="space-y-1">
                  <p class="text-[10px] font-black text-slate-300">플랫폼이 대신 받아드리는 정보</p>
                  <p class="text-[9px] font-bold text-slate-500 leading-relaxed">
                    다음 정보는 질문을 등록하지 않아도 루틴 파인더스가 <span class="text-indigo-400">신청 과정에서 수집</span>하여 호스트님께 전달합니다:<br/>
                    • 닉네임 및 프로필 이미지<br/>
                    • <span class="text-indigo-400/80">실제 입금자 성함 및 연락처</span> (입금 확인용)<br/>
                    • 과거 챌린지 수행 성공률<br/>
                    • 루파클럽 멤버십 여부 및 성장 아이덴티티
                  </p>
                </div>
             </div>

             <div class="p-5 bg-indigo-500/5 border border-indigo-500/10 rounded-2xl flex items-start gap-3">
                <span class="text-xl">🙋‍♂️</span>
                <div class="space-y-1">
                  <p class="text-[10px] font-black text-indigo-400">직접 물어보고 싶은 질문</p>
                  <p class="text-[9px] font-bold text-slate-500 leading-relaxed tabular-nums">
                    질문을 등록하면 참여자가 <span class="text-indigo-400">신청서를 작성할 때</span> 답변을 함께 제출하게 됩니다. 호스트님은 신청 내역에서 이 답변을 보고 참가를 수락할 수 있습니다.
                  </p>
                </div>
             </div>
           </div>
        </div>
      </section>

      <!-- STEP 7: Cost Details -->
      <section id="step-6" class="step-section hidden flex-1 flex flex-col gap-6">
        <div class="space-y-1">
          <h2 class="text-xl font-black text-white tracking-tighter leading-tight">참가비 정보를 <span class="text-indigo-500">안전</span>하게 입력해 주세요.</h2>
        </div>
        <div class="space-y-5">
           <div class="grid grid-cols-3 gap-2 overflow-visible p-1">
             <% [
                 { id: "free", label: "무료", desc: "자유로운 참여" },
                 { id: "fee", label: "참가비", desc: "수익 창출형" },
                 { id: "deposit", label: "보증금", desc: "동기 부여형" }
             ].each do |cost| %>
               <button type="button" data-val="<%= cost[:id] %>" class="cost-opt py-4 rounded-2xl border transition-all flex flex-col items-center gap-1 <%= cost[:id] == 'deposit' ? 'selected-cat' : 'unselected-opt' %>">
                 <span class="text-xs font-black"><%= cost[:label] %></span>
                 <span class="text-[8px] font-bold opacity-60"><%= cost[:desc] %></span>
               </button>
             <% end %>
           </div>

           <!-- Guidance Message (DYNAMIC) -->
           <div id="cost_guide_msg" class="p-4 bg-indigo-500/5 border border-indigo-500/10 rounded-2xl">
             <p class="text-[10px] font-bold text-indigo-400/80 leading-relaxed tabular-nums">
               💡 <span id="cost_guide_text">보증금 방식은 참여자의 동기부여를 높이고 성실한 참여를 유도하기에 가장 좋습니다.</span>
             </p>
           </div>

           <!-- Amount Container (DYNAMIC) -->
           <div id="cost_amount_box" class="space-y-2 p-1 overflow-visible">
             <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Amount (KRW)</label>
             <div class="relative">
               <%= f.number_field :amount, value: 10000, class: "glass-input w-full p-4 text-2xl text-right pr-12 focus:scale-[1.01] transition-transform", placeholder: "0" %>
               <span class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-500 font-bold">원</span>
             </div>
           </div>

           <!-- Deposit Specific Options (DYNAMIC) -->
           <div id="deposit_options" class="space-y-4">
             <!-- Toggle: Add Fee -->
             <div class="p-4 bg-white/5 rounded-2xl border border-white/5 space-y-4">
               <div class="flex items-center justify-between">
                 <div>
                   <p class="text-[11px] font-black text-white">참가비도 함께 받기</p>
                   <p class="text-[9px] font-bold text-slate-500 mt-0.5">보증금 외 별도의 운영비를 추가합니다</p>
                 </div>
                 <div class="toggle-pill cursor-pointer" id="toggle_add_fee">
                   <div class="toggle-circle"></div>
                 </div>
               </div>
               <div id="add_fee_input" class="hidden pt-2">
                 <div class="relative">
                   <%= f.number_field :participation_fee, value: 5000, class: "glass-input w-full p-3.5 text-sm text-right pr-10 focus:ring-2 focus:ring-indigo-500/20", placeholder: "0" %>
                   <span class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-500 text-xs font-bold">원</span>
                 </div>
               </div>
             </div>

             <!-- Penalty per failure -->
             <div class="p-4 bg-slate-900/50 rounded-2xl border border-white/5 space-y-3">
               <label class="text-[9px] font-black text-slate-500 uppercase tracking-widest pl-1">실패 차감액 설정</label>
               <div class="relative">
                 <%= f.number_field :penalty_per_failure, value: 2000, class: "glass-input w-full p-4 text-xl text-right pr-12 text-indigo-400 focus:scale-[1.01]", placeholder: "0" %>
                 <span class="absolute right-5 top-1/2 -translate-y-1/2 text-slate-600 font-bold">원</span>
               </div>
               <p class="text-[9px] font-bold text-slate-600 pl-1 leading-relaxed">1회 실패 시마다 보증금에서 차감되는 금액입니다.</p>
             </div>

             <!-- Refund Date -->
             <div class="space-y-2 p-1">
               <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Refund Date (환급 예정일)</label>
               <%= f.date_field :refund_date, value: (Date.current + 1.month).end_of_month, onclick: "this.showPicker()", class: "glass-input w-full p-4 text-sm" %>
             </div>
           </div>

           <!-- Bank Info Container (DYNAMIC) -->
           <div id="cost_bank_box" class="space-y-4 p-1 overflow-visible">
             <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Settlement Account (정산 계좌)</label>
             <div class="grid grid-cols-5 gap-2 p-1 overflow-visible">
                <% default_bank = @challenge.host_bank || current_user.saved_bank_name || '신한' %>
                <% @banks.each do |bank| %>
                  <button type="button" class="bank-opt py-2 rounded-lg border text-[10px] font-black transition-all <%= bank == default_bank ? 'selected-cat' : 'unselected-opt' %>" data-val="<%= bank %>"><%= bank %></button>
                <% end %>
                <%= f.hidden_field :host_bank, id: "h_bank", value: default_bank %>
             </div>
             <div class="grid grid-cols-2 gap-3">
                <%= f.text_field :host_account_holder, class: "glass-input w-full p-4 text-xs focus:scale-[1.01]", placeholder: "예금주 성함" %>
                <%= f.text_field :host_account, class: "glass-input w-full p-4 text-xs focus:scale-[1.01]", placeholder: "계좌번호 (- 없이)" %>
             </div>

             <div class="space-y-2 p-1 pt-2 border-t border-white/5">
               <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Refund Policy (환불 정책)</label>
               <%= f.text_area :refund_policy, class: "glass-input w-full p-4 text-[11px] min-h-[80px] leading-relaxed", placeholder: "유료 챌린지의 경우 참가 취소 및 중도 포기 시 환불 기준을 명시해주세요." %>
             </div>
           </div>

           <!-- Safety Disclaimer -->
           <div class="p-5 bg-amber-500/5 border border-amber-500/10 rounded-[28px] space-y-2.5">
              <div class="flex items-center gap-2 text-amber-500">
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <span class="text-[10px] font-black uppercase tracking-wider">안전한 운영을 위한 안내</span>
              </div>
              <p class="text-[9px] font-bold text-slate-500 leading-relaxed">
                참가비 및 보증금은 주최자의 <span class="text-amber-500/80">세심한 관리와 투명한 운영</span>이 필요합니다. 정산 과정에서 발생하는 모든 분쟁에 대한 책임은 전적으로 주최자에게 있습니다.
              </p>
           </div>
        </div>
      </section>

      <!-- STEP 8: Achievement Logic -->
      <section id="step-7" class="step-section hidden flex-1 flex flex-col gap-6">
        <div class="space-y-1">
          <h2 class="text-xl font-black text-white tracking-tighter leading-tight">달성률에 따른 <span class="text-indigo-500">환급 기준</span>을 정해주세요.</h2>
