<turbo-frame id="ranking_list" class="block space-y-10 pt-2 relative">
  <!-- Dynamic Arena Background Glow -->
  <div class="fixed top-0 left-1/2 -translate-x-1/2 w-full h-[600px] bg-gradient-to-b from-indigo-500/10 via-transparent to-transparent blur-[120px] pointer-events-none z-0"></div>
  <div class="fixed top-[200px] right-0 w-[300px] h-[300px] bg-purple-500/5 blur-[100px] rounded-full pointer-events-none z-0"></div>

  <div class="relative z-10 space-y-10">
  <!-- 1. Hall of Fame (Podium) -->
  <section class="space-y-6">
    <div class="text-center space-y-1">
      <h3 class="text-xs font-black text-indigo-400 uppercase tracking-[0.3em]">이달의 통합 성취 랭킹</h3>
      <p class="text-[10px] font-bold text-slate-500">모두가 함께 경쟁하고 성장하는 명예의 전당</p>
    </div>

    <!-- Podium Visual -->
    <div class="relative h-64 flex items-end justify-center gap-2 px-4">
      <!-- Top 2 -->
      <div class="flex flex-col items-center gap-3 w-24">
        <%= link_to prototype_user_card_path(@top_users[1]&.id || 0), data: { turbo_frame: "user-profile-modal-frame" }, class: "group contents" do %>
          <div class="relative">
            <div class="w-16 h-16 rounded-full border-4 border-slate-400 overflow-hidden shadow-2xl group-active:scale-95 transition-all duration-300">
              <img src="<%= @top_users[1]&.profile_image %>" class="w-full h-full object-cover">
            </div>
            <div class="absolute -top-2 -right-2 w-7 h-7 bg-slate-400 rounded-full flex items-center justify-center text-[#0C0B12] font-black border-2 border-[#0C0B12] text-[10px] shadow-lg">2</div>
          </div>
          <div class="w-full h-24 bg-slate-800/20 backdrop-blur-md rounded-t-[24px] border border-white/10 flex flex-col items-center justify-center group-hover:bg-slate-800/40 transition-all duration-300">
             <p class="text-[11px] font-black text-slate-300 line-clamp-1 px-2"><%= @top_users[1]&.nickname %></p>
             <div class="flex items-center gap-1 mt-1">
               <p class="text-[9px] font-black text-slate-500"><%= @monthly_rankings[1]&.dig(:score)&.round(1) || 0 %>P</p>
             </div>
          </div>
        <% end %>
      </div>

      <!-- Top 1 (Center) -->
      <div class="flex flex-col items-center gap-3 w-28 -translate-y-6">
        <%= link_to prototype_user_card_path(@top_users[0]&.id || 0), data: { turbo_frame: "user-profile-modal-frame" }, class: "group contents" do %>
          <div class="relative">
            <!-- Rotating Glow Ring -->
            <div class="absolute inset-[-6px] bg-gradient-to-tr from-amber-400 via-indigo-500 to-amber-300 rounded-full animate-spin-slow opacity-60 blur-sm"></div>
            <div class="relative w-20 h-20 rounded-full border-4 border-[#0C0B12] overflow-hidden shadow-2xl group-active:scale-95 transition-all duration-300">
              <img src="<%= @top_users[0]&.profile_image %>" class="w-full h-full object-cover">
              <!-- Golden Overlay Shine -->
              <div class="absolute inset-0 bg-gradient-to-tr from-amber-400/20 to-transparent pointer-events-none"></div>
            </div>
            <div class="absolute -top-3 -right-3 w-9 h-9 bg-gradient-to-br from-amber-300 to-amber-500 rounded-full flex items-center justify-center text-[#0C0B12] font-black border-4 border-[#0C0B12] text-sm shadow-xl z-20">👑</div>
          </div>
          <div class="w-full h-36 bg-gradient-to-b from-indigo-500/20 to-indigo-500/5 backdrop-blur-xl rounded-t-[24px] border border-indigo-500/40 flex flex-col items-center justify-center shadow-[0_0_30px_rgba(99,102,241,0.2)] group-hover:from-indigo-500/30 transition-all duration-300">
             <div class="flex items-center gap-1 px-2">
                <p class="text-[13px] font-black text-white line-clamp-1"><%= @top_users[0]&.nickname %></p>
             </div>
             <div class="flex items-center gap-1 mt-1.5 px-3 py-1 bg-indigo-500/20 rounded-full border border-indigo-500/30">
               <span class="w-1 h-1 rounded-full bg-indigo-400 animate-pulse"></span>
               <p class="text-[10px] font-black text-indigo-300"><%= @monthly_rankings[0]&.dig(:score)&.round(1) || 0 %>P</p>
             </div>
          </div>
        <% end %>
      </div>

      <!-- Top 3 -->
      <div class="flex flex-col items-center gap-3 w-24">
        <%= link_to prototype_user_card_path(@top_users[2]&.id || 0), data: { turbo_frame: "user-profile-modal-frame" }, class: "group contents" do %>
          <div class="relative">
            <div class="w-16 h-16 rounded-full border-4 border-amber-800/40 overflow-hidden shadow-2xl group-active:scale-95 transition-all duration-300">
              <img src="<%= @top_users[2]&.profile_image %>" class="w-full h-full object-cover">
            </div>
            <div class="absolute -top-2 -right-2 w-7 h-7 bg-amber-700 rounded-full flex items-center justify-center text-[#0C0B12] font-black border-2 border-[#0C0B12] text-[10px] shadow-lg">3</div>
          </div>
          <div class="w-full h-20 bg-slate-800/10 backdrop-blur-md rounded-t-[24px] border border-white/5 flex flex-col items-center justify-center group-hover:bg-slate-800/30 transition-all duration-300">
             <p class="text-[11px] font-black text-slate-400 line-clamp-1 px-2"><%= @top_users[2]&.nickname %></p>
             <div class="flex items-center gap-1 mt-0.5">
               <p class="text-[9px] font-black text-slate-600"><%= @monthly_rankings[2]&.dig(:score)&.round(1) || 0 %>P</p>
             </div>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <!-- 1.2 Previous Month Grandmasters -->
  <% if @prev_top_rankings.any? && @period != 'total' %>
    <section class="mt-4 pb-2 border-b border-white/5">
      <div class="flex items-center justify-between px-2 mb-4">
        <h3 class="text-xs font-black text-amber-500 uppercase tracking-[0.2em] flex items-center gap-1">
          <span>지난 달 명예의 전당</span>
          <span class="text-lg">👑</span>
        </h3>
        <p class="text-[9px] font-bold text-slate-500"><%= 1.month.ago.strftime('%m월') %> 시즌 최종 Top 3</p>
      </div>
      
      <div class="space-y-3 px-2">
        <% @prev_top_rankings.each_with_index do |ranking, index| %>
          <% user = ranking[:user] %>
          <%= link_to prototype_user_card_path(user.id), data: { turbo_frame: "user-profile-modal-frame" }, class: "flex items-center justify-between p-4 bg-gradient-to-r from-amber-500/10 to-transparent border border-amber-500/20 rounded-2xl hover:bg-amber-500/20 transition-colors" do %>
            <div class="flex items-center gap-4">
              <div class="w-8 h-8 rounded-full border-2 <%= index == 0 ? 'border-amber-400 shadow-[0_0_10px_rgba(251,191,36,0.6)]' : 'border-slate-500' %> overflow-hidden shrink-0">
                <img src="<%= user.profile_image %>" class="w-full h-full object-cover">
              </div>
              <div>
                <div class="flex items-center gap-1.5">
                  <span class="text-sm font-black text-white"><%= user.nickname %></span>
                  <% if index == 0 %>
                    <span class="px-1.5 py-0.5 rounded text-[8px] font-black bg-amber-500 text-[#0C0B12]">그랜드마스터 1위</span>
                  <% else %>
                    <span class="text-[9px] font-bold text-amber-600/80">그랜드마스터 <%= index + 1 %>위</span>
                  <% end %>
                </div>
                <p class="text-[9px] font-bold text-slate-400">Lv.<%= user.level %> • <%= ranking[:score].round %> RP</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- 1.5 Integrated Leaderboard Table -->
  <section class="space-y-4">
    <div class="flex justify-between items-center px-2">
      <h3 class="text-xs font-black text-slate-500 uppercase tracking-[0.2em]">🏆 리더보드</h3>
      <div class="flex items-center gap-2">
        <button type="button" 
                onclick="document.getElementById('score-guide-modal').classList.remove('hidden')"
                class="px-2 py-0.5 bg-indigo-500/10 rounded-full flex items-center gap-1 hover:bg-indigo-500/20 transition-colors">
          <span class="text-[8px] font-black text-indigo-400">포인트 기준</span>
          <svg class="w-2.5 h-2.5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        </button>
        <p class="text-[10px] font-bold text-indigo-400"><%= Date.current.strftime('%Y년 %m월') %></p>
      </div>
    </div>

    <!-- Ranking List Partial (Turbo Frame is inside the partial) -->
    <%= render partial: "ranking_list", locals: { rankings: @monthly_rankings, period: @period || 'monthly' } %>
  </section>

  <!-- Full Ranking Modal -->
  <div id="full-ranking-modal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-0 sm:p-4">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="this.parentElement.classList.add('hidden')"></div>
    <div class="relative w-full max-w-lg h-[90vh] sm:h-[80vh] bg-[#0C0B12] rounded-t-[40px] sm:rounded-[40px] border-t sm:border border-white/10 flex flex-col overflow-hidden animate-slide-up">
      <!-- Modal Header -->
      <div class="sticky top-0 z-20 bg-[#0C0B12] p-6 border-b border-white/5">
        <div class="flex justify-between items-center mb-4">
          <h4 class="text-lg font-black text-white">전체 통합 리더보드</h4>
          <button onclick="this.closest('#full-ranking-modal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400">✕</button>
        </div>
        <div class="flex items-center gap-2">
          <% if @my_ranking %>
            <div class="flex-1 p-4 bg-indigo-600/20 border border-indigo-500/30 rounded-2xl flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-xs font-black text-indigo-400">#<%= @my_ranking[:rank] %></span>
                <span class="text-[11px] font-bold text-white"><%= current_user.nickname %>님 (나)</span>
              </div>
              <span class="text-xs font-black text-indigo-400"><%= @my_ranking[:score] %>P</span>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Modal Body -->
      <div class="flex-1 overflow-y-auto p-4 space-y-2 pb-[160px]">
        <% @monthly_rankings.each_with_index do |ranking, index| %>
          <% user = ranking[:user] %>
          <%= link_to prototype_user_card_path(user), data: { turbo_frame: "user-profile-modal-frame" }, class: "flex items-center justify-between p-4 #{user == current_user ? 'bg-indigo-600/10 border border-indigo-500/20' : 'bg-white/[0.03]'} rounded-2xl hover:bg-white/[0.08] transition-colors" do %>
            <div class="flex items-center gap-4">
              <div class="w-6 text-center text-[10px] font-black <%= index < 3 ? 'text-amber-400' : 'text-slate-500' %>"><%= index + 1 %></div>
              <div class="w-8 h-8 rounded-lg overflow-hidden shrink-0">
                <img src="<%= user.profile_image %>" class="w-full h-full object-cover">
              </div>
              <div>
                <div class="flex items-center gap-1.5">
                  <span class="text-xs font-black text-white line-clamp-1"><%= user.nickname %></span>
                  <% if ranking[:is_club] %>
                    <span class="text-[8px]">🔱</span>
                  <% end %>
                </div>
                <p class="text-[8px] font-bold text-slate-500">Lv.<%= user.level %></p>
              </div>
            </div>
            <p class="text-xs font-bold text-white"><%= ranking[:score] %>P</p>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Score Guide Modal -->
  <div id="score-guide-modal" class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="this.parentElement.classList.add('hidden')"></div>
    <div class="relative w-full max-w-sm bg-[#1B1A24] rounded-[32px] border border-white/10 p-8 animate-badge-pop shadow-2xl">
      <div class="flex justify-between items-start mb-6">
        <div>
          <h3 class="text-xl font-black text-white mb-1">🏆 랭킹 포인트 기준</h3>
          <p class="text-[10px] font-bold text-slate-500">성공률(80%) + 노력량 점수가 합산됩니다.</p>
        </div>
        <button onclick="this.closest('#score-guide-modal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:text-white hover:bg-white/10 transition-colors">✕</button>
      </div>
      
      <div class="space-y-3">
        <div class="flex justify-between items-center p-3 rounded-xl bg-white/5 border border-white/5">
          <div class="flex items-center gap-3">
            <span class="text-lg">📈</span>
            <span class="text-xs font-bold text-white">루틴 달성률 (성공률)</span>
          </div>
          <span class="text-xs font-black text-indigo-400">Max 50 P</span>
        </div>
        <div class="flex justify-between items-center p-3 rounded-xl bg-white/5 border border-white/5">
          <div class="flex items-center gap-3">
            <span class="text-lg">📅</span>
            <span class="text-xs font-bold text-white">월간 출석률 (성실도)</span>
          </div>
          <span class="text-xs font-black text-indigo-400">Max 30 P</span>
        </div>
        <div class="flex justify-between items-center p-3 rounded-xl bg-indigo-500/10 border border-indigo-500/20">
          <div class="flex items-center gap-3">
            <span class="text-lg">🔥</span>
            <span class="text-xs font-bold text-white font-black">루틴 노력 점수 (절대량)</span>
          </div>
          <span class="text-xs font-black text-indigo-400">횟수당 +0.5 P</span>
        </div>
        <div class="pt-2 pb-1">
          <p class="text-[9px] font-bold text-slate-500 px-1">* 루틴 개수가 많을수록 더 높은 노력 점수를 획득합니다.</p>
        </div>
      </div>

      <div class="mt-6">
        <button onclick="document.getElementById('point-detail-modal').classList.remove('hidden')" 
                class="w-full py-4 bg-indigo-500/10 hover:bg-indigo-500/20 border border-indigo-500/30 rounded-2xl text-[11px] font-black text-indigo-400 transition-all flex items-center justify-center gap-2 group">
          <span>시스템 상세 가이드 보기</span>
          <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Detailed Point Guide Modal -->
  <div id="point-detail-modal" class="hidden fixed inset-0 z-[110] flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/95 backdrop-blur-xl" onclick="this.parentElement.classList.add('hidden')"></div>
    <div class="relative w-full max-w-sm h-[80vh] bg-[#0C0B12] rounded-[40px] border border-white/20 flex flex-col overflow-hidden animate-slide-up">
      <!-- Header -->
      <div class="p-8 pb-4 flex justify-between items-center shrink-0">
        <div>
          <h4 class="text-xl font-black text-white">포인트 시스템 가이드</h4>
          <p class="text-[10px] font-bold text-slate-500 mt-1 uppercase tracking-widest">Mastering the Routine System</p>
        </div>
        <button onclick="this.closest('#point-detail-modal').classList.add('hidden')" class="w-8 h-8 rounded-full bg-white/5 flex items-center justify-center text-slate-400">✕</button>
      </div>

      <!-- Content -->
      <div class="flex-1 overflow-y-auto p-8 pt-2 space-y-8 custom-scrollbar">
        <!-- Intro Message (Moved to Top) -->
        <div class="p-6 bg-indigo-500/10 border border-indigo-500/20 rounded-[28px] text-center space-y-1.5">
           <p class="text-[11px] font-black text-white leading-relaxed">루파 클럽은 성실함과 노력을 보상합니다.</p>
           <p class="text-[10px] font-bold text-slate-400 leading-relaxed">많은 루틴을 꾸준히 실천하는 유저가<br/>가장 높은 점수를 받을 수 있도록 설계되었습니다.</p>
        </div>

        <!-- 1. Platform Level -->
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-indigo-500"></span>
            <h5 class="text-xs font-black text-indigo-400 uppercase tracking-widest">1. 플랫폼 레벨 포인트</h5>
          </div>
          <div class="p-5 bg-white/[0.03] border border-white/5 rounded-3xl space-y-3">
             <p class="text-[9px] font-bold text-slate-500 mb-2">플랫폼 전체에서 사용되는 경험치 포인트입니다.</p>
             <div class="flex justify-between items-center text-[11px] font-bold">
               <span class="text-slate-400">루틴 완료 (1회당)</span>
               <span class="text-white">+10P</span>
             </div>
             <div class="flex justify-between items-center text-[11px] font-bold">
               <span class="text-slate-400">오늘의 확언 작성</span>
               <span class="text-white">+5P</span>
             </div>
             <div class="flex justify-between items-center text-[11px] font-bold">
               <span class="text-slate-400">모임/챌린지 개설</span>
               <span class="text-white">+60P</span>
             </div>
          </div>
        </div>

        <!-- 2. Club Growth Points -->
        <div class="space-y-4">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
            <h5 class="text-xs font-black text-emerald-400 uppercase tracking-widest">2. 루파 클럽 통합 랭킹 점수</h5>
          </div>
          <div class="p-5 bg-emerald-500/[0.02] border border-emerald-500/10 rounded-3xl space-y-4">
             <p class="text-[9px] font-bold text-slate-500">이달의 랭킹을 결정하는 복합 산정 점수입니다.</p>
             <div class="space-y-2">
               <div class="flex justify-between items-center text-[11px] font-bold">
                 <span class="text-slate-300">월간 출석률 (성실도)</span>
                 <span class="text-white">최대 30P</span>
               </div>
               <div class="flex justify-between items-center text-[11px] font-bold">
                 <span class="text-slate-300">루틴 달성률 (성공률)</span>
                 <span class="text-white">최대 50P</span>
               </div>
               <div class="flex justify-between items-center text-[11px] font-bold py-2 border-y border-white/5">
                 <span class="text-emerald-400 font-black">루틴 노력 점수 (절대량)</span>
                 <span class="text-emerald-400 font-black">횟수당 +0.5P</span>
               </div>
             </div>
             <p class="text-[9px] leading-relaxed text-slate-500">* [예시] 하루 5개 루틴 수행 시 한 달간 약 75점의 추가 점수를 획득하여 랭킹에 압도적으로 유리해집니다.</p>
          </div>
        </div>

        <!-- 4. Strategic Core Tips -->
        <div class="space-y-4 pb-12">
          <div class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
            <h5 class="text-xs font-black text-amber-500 uppercase tracking-widest">💡 랭킹 정복을 위한 전략 팁</h5>
          </div>
          <div class="space-y-4">
             <div class="flex gap-3">
               <span class="text-xs shrink-0">🚀</span>
               <p class="text-[11px] font-bold text-slate-400 leading-relaxed">성공률뿐만 아니라 <strong class="text-white">수행 횟수(절대량)</strong>가 중요합니다. 루틴 개수를 늘릴수록 높은 랭킹 점수를 쌓을 수 있습니다.</p>
             </div>
             <div class="flex gap-3">
               <span class="text-xs shrink-0">💎</span>
               <p class="text-[11px] font-bold text-slate-400 leading-relaxed">포기하지 마세요! 달성률이 조금 낮더라도 <strong class="text-white">꾸준히 많은 루틴을 실천</strong>하는 것이 랭킹 상위권 유지의 열쇠입니다.</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>




  </div>
</turbo-frame>

