            <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Participation Restriction</label>
            <div class="p-5 rounded-[28px] bg-indigo-500/5 border border-indigo-500/10 flex items-center justify-between group/premium cursor-pointer active:scale-[0.98] transition-all" id="btn_rufa_only">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-indigo-500/20 flex items-center justify-center text-xl">⚡</div>
                <div>
                  <p class="text-[11px] font-black text-white">루파클럽 전용</p>
                  <p class="text-[9px] font-bold text-indigo-400/60 mt-0.5">멤버십 회원들만 참여할 수 있습니다</p>
                </div>
              </div>
              <div class="toggle-pill" id="toggle_rufa_only">
                <div class="toggle-circle"></div>
              </div>
              <%= f.hidden_field :for_rufa_club_members_only, id: "h_rufa_only", value: "false" %>
            </div>
          </div>
        </div>
      </section>
      
      <!-- STEP 6: Participant Information (NEW) -->
      <section id="step-5" class="step-section hidden flex-1 flex flex-col gap-6">
        <div class="space-y-1">
          <h2 class="text-xl font-black text-white tracking-tighter leading-tight">참여자에게 <span class="text-indigo-500">궁금한 점</span>이 있으신가요?</h2>
        </div>
