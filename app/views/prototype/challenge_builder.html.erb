               <div id="review_days" class="flex gap-1 flex-wrap"></div>
             </div>
           </div>

           <!-- Review: Verification & Participation -->
           <div class="grid grid-cols-2 gap-3">
             <div class="bg-white/5 rounded-[24px] p-5 space-y-2 border border-white/5">
               <p class="text-[9px] font-black text-slate-600 uppercase">Verification</p>
               <p id="review_vtype" class="text-sm font-black text-white">사진 인증</p>
               <p id="review_vtime" class="text-[9px] font-bold text-slate-500"></p>
               <div id="review_vapproval" class="hidden pt-2 border-t border-white/5">
                 <p class="text-[9px] font-bold text-amber-400">✓ 호스트 승인 필요</p>
               </div>
             </div>
             <div class="bg-white/5 rounded-[24px] p-5 space-y-2 border border-white/5">
               <p class="text-[9px] font-black text-slate-600 uppercase">Participation</p>
               <p id="review_admission" class="text-sm font-black text-white">선착순</p>
               <p id="review_max" class="text-[9px] font-bold text-slate-500">최대 30명</p>
               <div id="review_rufa_only" class="hidden pt-2 border-t border-white/5">
                 <p class="text-[9px] font-bold text-indigo-400">⚡ 루파클럽 전용</p>
               </div>
             </div>
           </div>

           <!-- Review: Cost & Achievement -->
           <div class="bg-white/5 rounded-[32px] p-6 space-y-4 border border-white/5">
             <div class="flex justify-between items-center">
               <div>
                 <p class="text-[9px] font-black text-slate-600 uppercase">Cost Type</p>
                 <p id="review_cost" class="text-xl font-black text-white">10,000원</p>
               </div>
               <div id="review_penalty_box" class="hidden text-right">
                 <p class="text-[9px] font-black text-slate-600 uppercase">Penalty</p>
                 <p id="review_penalty" class="text-sm font-black text-red-400"></p>
               </div>
             </div>
             <div id="review_achievement_box" class="hidden grid grid-cols-2 gap-3 pt-3 border-t border-white/5">
               <div class="text-center">
                 <p class="text-[9px] font-black text-slate-600 uppercase">Full Refund</p>
                 <p id="review_full_refund" class="text-lg font-black text-indigo-400">85%</p>
               </div>
               <div class="text-center">
                 <p class="text-[9px] font-black text-slate-600 uppercase">Max Failures</p>
                 <p id="review_max_failures" class="text-lg font-black text-purple-400">3회</p>
               </div>
             </div>
             <div id="review_bank_box" class="hidden pt-3 border-t border-white/5">
               <p class="text-[9px] font-black text-slate-600 uppercase mb-1">Settlement Account</p>
               <p id="review_bank" class="text-xs font-bold text-slate-400"></p>
             </div>
             <div id="review_refund_policy_box" class="hidden pt-3 border-t border-white/5">
               <p class="text-[9px] font-black text-slate-600 uppercase mb-1">Refund Policy</p>
               <p id="review_refund_policy" class="text-[9px] font-bold text-slate-400 leading-relaxed line-clamp-3"></p>
             </div>
           </div>

           <!-- Review: Rewards (if any) -->
           <div id="review_rewards_box" class="hidden bg-white/5 rounded-[32px] p-6 space-y-3 border border-white/5">
             <p class="text-xs font-black text-indigo-400 uppercase tracking-wider">Winner Benefits</p>
             <div id="review_rewards" class="space-y-2">
               <!-- Rewards will be injected here -->
             </div>
           </div>

           <!-- Review: Additional Info -->
           <div id="review_additional_box" class="hidden bg-white/5 rounded-[24px] p-5 space-y-2 border border-white/5">
             <p class="text-[9px] font-black text-slate-600 uppercase">Additional Settings</p>
             <div id="review_additional" class="space-y-1 text-[9px] font-bold text-slate-400">
               <!-- Additional settings will be injected here -->
             </div>
           </div>

           <div class="p-6 bg-slate-900 border border-white/5 rounded-[32px]">
              <p class="text-[10px] font-bold text-slate-500 text-center leading-relaxed">부적절한 챌린지는 운영 정책에 따라 <br/>사전 통보 없이 삭제될 수 있습니다.</p>
           </div>
        </div>
      </section>

    </div>

    <!-- Global Footer Button -->
    <div class="py-4 pb-8 shrink-0 z-20">
      <button id="nextBtn" type="button" class="w-full py-5 rounded-3xl bg-indigo-500 text-white font-black text-base shadow-lg shadow-indigo-500/40 active:scale-95 transition-all">
        다음 단계로
      </button>
      <button id="submitBtn" type="button" class="hidden w-full py-5 rounded-3xl bg-indigo-500 text-white font-black text-lg shadow-lg shadow-indigo-500/40 active:scale-90 transition-all">
        챌린지 개설 완료
      </button>
    </div>
  <% end %>
</div>

<script>
  (function() {
    const sections = document.querySelectorAll('.step-section');
    const dots = document.querySelectorAll('.step-dot');
    const nextBtn = document.getElementById('nextBtn');
    const submitBtn = document.getElementById('submitBtn');
    const prevBtn = document.getElementById('prevBtn');
    const stepCounter = document.getElementById('stepCounter');
    
    // Multiple Questions DOM
    const questionsList = document.getElementById('questions_list');
    const addQuestionBtn = document.getElementById('add_question_btn');
    const questionsHidden = document.getElementById('h_application_questions');

    let currentStep = 0;
    let isFormDirty = false; // Moved to top scope

    function formatNumber(num) {
      return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ",");
    }

    function generateRandomCode() {
      const code = 'RF-' + Math.floor(1000 + Math.random() * 9000);
      document.getElementById('h_inv_code').value = code;
      const copyTarget = document.getElementById('copy_target');
      if (copyTarget) copyTarget.textContent = code;
    }
    generateRandomCode();

    function smartScroll(el) {
      if (!el) return;
      setTimeout(() => {
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 100);
    }

    function previewImage(input, previewId) {
      const preview = document.getElementById(previewId);
      if (!input.files || !input.files[0]) return;
      const file = input.files[0];

      if (!file.type.match('image.*')) {
          alert("이미지 파일(JPG, PNG 등)만 등록할 수 있습니다.");
          input.value = "";
          return;
      }

      if (file.size > 5 * 1024 * 1024) {
          alert("이미지 크기는 5MB를 초과할 수 없습니다.");
          input.value = "";
          return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover rounded-2xl">`;
        preview.classList.remove('border-dashed', 'bg-white/5');
        preview.classList.add('border-solid', 'border-indigo-500/30');
      };
      reader.readAsDataURL(file);
    }

    // Aurora Update Logic
    const aurora = document.getElementById('aurora-glow');

    function update() {
      sections.forEach((s, i) => {
        s.classList.toggle('active', i === currentStep);
      });
      dots.forEach((d, i) => {
        d.classList.toggle('active-dot', i === currentStep);
        d.classList.toggle('pending-dot', i > currentStep);
        d.classList.toggle('completed-dot', i < currentStep);
      });
      stepCounter.textContent = `${currentStep+1}/10`;
      
      const activeSection = sections[currentStep];
      if (activeSection) {
        activeSection.parentElement.scrollTo({ top: 0, behavior: 'smooth' });
      }

      if (currentStep === 9) {
        nextBtn.classList.add('hidden');
        submitBtn.classList.remove('hidden');

        // === 1. Basic Info ===
        document.getElementById('review_title').textContent = document.querySelector('input[name="challenge[title]"]').value || "무제 챌린지";
        document.getElementById('review_summary').textContent = document.querySelector('input[name="challenge[summary]"]').value || "";
        document.getElementById('review_cat').textContent = "#" + (document.getElementById('h_category').value || "HEALTH");
        
        // Preparation items
        const preparation = document.querySelector('textarea[name="challenge[preparation_items]"]').value;
        if (preparation) {
          document.getElementById('review_preparation').textContent = preparation;
          document.getElementById('review_preparation_box').classList.remove('hidden');
        } else {
          document.getElementById('review_preparation_box').classList.add('hidden');
        }
        
        // === 2. Schedule ===
        const cStart = document.querySelector('input[name="challenge[start_date]"]').value;
        const cEnd = document.querySelector('input[name="challenge[end_date]"]').value;
        document.getElementById('review_period').textContent = `${cStart.slice(5)} ~ ${cEnd.slice(5)}`;
        
        const rEnd = document.querySelector('input[name="challenge[recruitment_end_date]"]').value;
        document.getElementById('review_recruitment').textContent = `~ ${rEnd.slice(5)}`;

        // === 3. Mission Goals ===
        const mode = document.getElementById('h_goal_mode').value;
        const goalsContainer = document.getElementById('review_goals');
        goalsContainer.innerHTML = '';
        
        if (mode === 'fixed') {
          const items = JSON.parse(document.getElementById('h_certification_goal').value || "[]");
          if (items.length > 0) {
            items.forEach(item => {
              goalsContainer.innerHTML += `<p class="text-sm font-bold text-white">• ${item}</p>`;
            });
          } else {
            goalsContainer.innerHTML = '<p class="text-sm font-bold text-slate-500">목표 미설정</p>';
          }
        } else {
          const daily = JSON.parse(document.getElementById('h_daily_goals').value || "{}");
          const daysData = Object.keys(daily);
          if (daysData.length > 0) {
            daysData.forEach(day => {
              const goals = daily[day];
              goalsContainer.innerHTML += `<div class="space-y-1"><p class="text-xs font-black text-indigo-400">${day}요일</p>`;
              goals.forEach(g => {
                goalsContainer.innerHTML += `<p class="text-sm font-bold text-white pl-3">• ${g}</p>`;
              });
              goalsContainer.innerHTML += `</div>`;
            });
          } else {
            goalsContainer.innerHTML = '<p class="text-sm font-bold text-slate-500">목표 미설정</p>';
          }
        }

        // Active Days
        const days = JSON.parse(document.getElementById('h_days').value || "[]");
        const daysContainer = document.getElementById('review_days');
        daysContainer.innerHTML = days.map(d => 
          `<span class="px-2 py-1 bg-indigo-500/20 rounded-lg text-[9px] font-black text-indigo-400">${d}</span>`
        ).join('');

        // === 4. Verification ===
        const vtypeMap = { photo: "사진 인증", simple: "간편 인증", metric: "수치 기록", url: "링크 제출" };
        document.getElementById('review_vtype').textContent = vtypeMap[document.getElementById('h_v_type').value];
        
        const vStart = document.querySelector('input[name="challenge[verification_start_time]"]').value;
        const vEnd = document.querySelector('input[name="challenge[verification_end_time]"]').value;
        document.getElementById('review_vtime').textContent = `${vStart} ~ ${vEnd}`;
        
        const requiresApproval = document.getElementById('h_requires_approval').value === 'true';
        document.getElementById('review_vapproval').classList.toggle('hidden', !requiresApproval);

        // === 5. Participation ===
        const admissionMap = { first_come: "선착순 입장", approval: "호스트 승인 후 입장" };
        document.getElementById('review_admission').textContent = admissionMap[document.getElementById('h_admission').value];
        
        const maxPart = document.querySelector('input[name="challenge[max_participants]"]').value;
        document.getElementById('review_max').textContent = `최대 ${maxPart}명`;
        
        const rufaOnly = document.getElementById('h_rufa_only').value === 'true';
        document.getElementById('review_rufa_only').classList.toggle('hidden', !rufaOnly);

        // === 6. Cost & Achievement ===
        const costType = document.getElementById('h_cost_type').value;
        const costTypeMap = { free: "무료", fee: "참가비", deposit: "보증금" };
        
        if (costType === 'free') {
          document.getElementById('review_cost').textContent = "무료";
          document.getElementById('review_penalty_box').classList.add('hidden');
          document.getElementById('review_achievement_box').classList.add('hidden');
          document.getElementById('review_bank_box').classList.add('hidden');
          document.getElementById('review_refund_policy_box').classList.add('hidden');
        } else {
          const amount = document.querySelector('input[name="challenge[amount]"]').value || "0";
          document.getElementById('review_cost').textContent = `${costTypeMap[costType]} ${formatNumber(amount)}원`;
          
          // Penalty (deposit only)
          if (costType === 'deposit') {
            const penalty = document.querySelector('input[name="challenge[penalty_per_failure]"]').value || "0";
            document.getElementById('review_penalty').textContent = `${formatNumber(penalty)}원/회`;
            document.getElementById('review_penalty_box').classList.remove('hidden');
            
            // Achievement thresholds
            const fullRefund = document.getElementById('input_full_refund').value;
            const maxFailures = document.getElementById('input_failure_tolerance').value;
            document.getElementById('review_full_refund').textContent = `${fullRefund}%`;
            document.getElementById('review_max_failures').textContent = `${maxFailures}회`;
            document.getElementById('review_achievement_box').classList.remove('hidden');
          } else {
            document.getElementById('review_penalty_box').classList.add('hidden');
            document.getElementById('review_achievement_box').classList.add('hidden');
          }
          
          // Bank info
          const bank = document.getElementById('h_bank').value;
          const holder = document.querySelector('input[name="challenge[host_account_holder]"]').value;
          const account = document.querySelector('input[name="challenge[host_account]"]').value;
          
          if (bank) {
            document.getElementById('review_bank').textContent = `${bank}${account ? ' ' + account : ''}${holder ? ' (' + holder + ')' : ''}`;
            document.getElementById('review_bank_box').classList.remove('hidden');
          } else {
            document.getElementById('review_bank_box').classList.add('hidden');
          }
          
          // Refund policy
          const refundPolicy = document.querySelector('textarea[name="challenge[refund_policy]"]').value;
          if (refundPolicy) {
            document.getElementById('review_refund_policy').textContent = refundPolicy;
            document.getElementById('review_refund_policy_box').classList.remove('hidden');
          } else {
            document.getElementById('review_refund_policy_box').classList.add('hidden');
          }
        }

        // === 7. Rewards ===
        const rewards = JSON.parse(document.getElementById('h_reward_policy').value || "[]");
        if (rewards.length > 0) {
          const rewardsContainer = document.getElementById('review_rewards');
          rewardsContainer.innerHTML = rewards.map(r => 
            `<div class="flex justify-between items-center p-3 bg-white/5 rounded-xl">
              <span class="text-sm font-black text-white">${r.rank}</span>
              <span class="text-xs font-bold text-indigo-400">${r.benefit || r.reward || r.description || ''}</span>
            </div>`
          ).join('');
          document.getElementById('review_rewards_box').classList.remove('hidden');
        } else {
          document.getElementById('review_rewards_box').classList.add('hidden');
        }

        // === 8. Additional Settings ===
        const additionalContainer = document.getElementById('review_additional');
        const additionalItems = [];
        
        const isPrivate = document.getElementById('h_is_private').value === 'true';
        if (isPrivate) {
          const invCode = document.getElementById('h_inv_code').value;
          additionalItems.push(`🔒 비공개 챌린지 (초대코드: ${invCode})`);
        }
        
        const requiresMsg = document.getElementById('h_requires_msg').value === 'true';
        if (requiresMsg) {
          const questions = JSON.parse(document.getElementById('h_application_questions').value || "[]");
          if (questions.length > 0) {
            questions.forEach((q, idx) => {
              additionalItems.push(`📝 질문 ${idx+1}: "${q}"`);
            });
          } else {
             additionalItems.push(`📝 신청 시 참여 동기 질문`);
          }
        }
        
        const reVerify = document.getElementById('h_reverify').value === 'true';
        if (reVerify) {
          additionalItems.push(`✓ 실패 시 당일 재인증 가능`);
        }
        
        if (additionalItems.length > 0) {
          additionalContainer.innerHTML = additionalItems.map(item => `<p>• ${item}</p>`).join('');
          document.getElementById('review_additional_box').classList.remove('hidden');
        } else {
          document.getElementById('review_additional_box').classList.add('hidden');
        }

      } else {
        nextBtn.classList.remove('hidden');
        submitBtn.classList.add('hidden');
      }
    }

    function previewImage(input, previewId) {
      if (!input.files || !input.files[0]) return;
      const file = input.files[0];

      if (!file.type.match('image.*')) {
          alert("이미지 파일(JPG, PNG 등)만 등록할 수 있습니다.");
          input.value = "";
          return;
      }

      if (file.size > 5 * 1024 * 1024) {
          alert("이미지 크기는 5MB를 초과할 수 없습니다.");
          input.value = "";
          return;
      }

      const reader = new FileReader();
      reader.onload = function(e) {
        const preview = document.getElementById(previewId);
        preview.innerHTML = `<img src="${e.target.result}" class="w-full h-full object-cover">`;
        preview.classList.remove('bg-white/5', 'border-dashed');
        preview.classList.add('border-solid', 'border-indigo-500/20');
      }
      reader.readAsDataURL(file);
    }

    // Validation Logic
    function validateChallengeStep(step) {
      if (step === 0) {
         const title = document.querySelector('input[name="challenge[title]"]').value.trim();
         const summary = document.querySelector('input[name="challenge[summary]"]').value.trim();
         if(!title) { alert('챌린지 이름을 입력해주세요.'); return false; }
         if(!summary) { alert('한 줄 소개를 입력해주세요.'); return false; }
      }
       else if (step === 1) {
          syncGoals();
          const mode = document.getElementById('h_goal_mode').value;
          if(mode === 'fixed') {
              const goals = JSON.parse(hCertificationGoal.value || "[]");
              if(goals.length === 0) { alert('최소 하나 이상의 목표 항목을 입력해주세요.'); return false; }
          } else {
              const days = JSON.parse(document.getElementById('h_days').value || "[]");
              if(days.length === 0) { alert('최소 하루 이상의 요일별 목표를 설정해주세요.'); return false; }
          }
       }
      else if (step === 2) {
         const rs = document.querySelector('input[name="challenge[recruitment_start_date]"]').value;
         const re = document.querySelector('input[name="challenge[recruitment_end_date]"]').value;
         const s = document.querySelector('input[name="challenge[start_date]"]').value;
         const e = document.querySelector('input[name="challenge[end_date]"]').value;
         
         if(!rs || !re) { alert('모집 기간을 설정해주세요.'); return false; }
         if(!s || !e) { alert('챌린지 수행 기간을 설정해주세요.'); return false; }
         
         // Optional: Check logic (start > end, etc.)? Simplified for now.
      }
      else if (step === 6) {
         const costType = document.getElementById('h_cost_type').value;
         if(costType !== 'free') {
           const amount = document.querySelector('input[name="challenge[amount]"]').value;
           const bank = document.getElementById('h_bank').value;
           const account = document.querySelector('input[name="challenge[host_account]"]').value.trim();
           const holder = document.querySelector('input[name="challenge[host_account_holder]"]').value.trim();
           
           if(!amount || parseInt(amount) <= 0) { alert('금액을 올바르게 입력해주세요.'); return false; }
           if(!bank) { alert('정산 은행을 선택해주세요.'); return false; }
           if(!holder) { alert('예금주명을 입력해주세요.'); return false; }
           if(!account) { alert('계좌번호를 입력해주세요.'); return false; }
         }
      }
      
      return true;
    }

    // Nav
    nextBtn.addEventListener('click', () => {
      if (currentStep < 9) { 
        if(validateChallengeStep(currentStep)) {
          currentStep++;
          update();
        }
      }
    });

    submitBtn.addEventListener('click', (e) => {
      if(validateChallengeStep(currentStep)) {
        isFormDirty = false; // Reset dirty flag
        
        // Premium Completion: Confetti Trigger
        if (typeof confetti !== 'undefined') {
          confetti({
            particleCount: 150,
            spread: 70,
            origin: { y: 0.6 },
            colors: ['#818cf8', '#c084fc', '#ffffff']
          });
        }
        
        // Slight delay for effect
        setTimeout(() => {
          submitBtn.closest('form').submit();
        }, 800);
      } else {
        e.preventDefault();
      }
    });

    prevBtn.addEventListener('click', () => {
      if (currentStep > 0) {
        currentStep--;
        update();
      } else {
        window.history.back();
      }
    });

    // Reward Policy Logic
    const rewardList = document.getElementById('reward_list');
    const addRewardBtn = document.getElementById('add_reward_btn');
    const hRewardPolicy = document.getElementById('h_reward_policy'); // Assuming this hidden field exists or will be added

    function updateRewardJSON() {
      const rows = rewardList.querySelectorAll('.reward-row');
      const data = Array.from(rows).map(row => ({
        rank: row.querySelector('.rank-input').value,
        benefit: row.querySelector('.benefit-input').value
      }));
      hRewardPolicy.value = JSON.stringify(data);
    }

    function addRewardRow(rank = "", benefit = "") {
      const div = document.createElement('div');
      div.className = "reward-row flex items-center gap-2 p-3 bg-white/5 rounded-2xl border border-white/5 animate-fade-in";
      div.innerHTML = `
        <input type="text" placeholder="순위 (예: 1위)" value="${rank}" class="rank-input bg-transparent border-none p-0 text-xs font-black text-indigo-400 w-20 focus:ring-0">
        <div class="h-4 w-[1px] bg-white/10"></div>
        <input type="text" placeholder="혜택 (예: 스타벅스 쿠폰)" value="${benefit}" class="benefit-input bg-transparent border-none p-0 text-xs font-bold text-white flex-1 focus:ring-0">
        <button type="button" class="remove-reward-btn p-2 text-slate-500 hover:text-red-400 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      `;
      div.querySelector('.remove-reward-btn').addEventListener('click', () => {
        div.remove();
        updateRewardJSON();
      });
      div.querySelectorAll('input').forEach(input => {
        input.addEventListener('input', updateRewardJSON);
      });
      rewardList.appendChild(div);
      updateRewardJSON();
    }

    addRewardBtn.addEventListener('click', () => addRewardRow());

    // Multi-Selection Logic
    const handleSelect = (btns, hiddenId, activeClass, callback) => {
      btns.forEach(btn => {
        btn.addEventListener('click', () => {
          btns.forEach(b => {
             b.classList.remove(activeClass, 'selected-cat', 'premium-selection');
             b.classList.add('unselected-opt');
          });
          btn.classList.add(activeClass);
          btn.classList.remove('unselected-opt');
          if(hiddenId) document.getElementById(hiddenId).value = btn.dataset.val;

          if(callback) callback(btn.dataset.val);
          smartScroll(btn);
          update();
        });
      });
    };

    // Mission Goal Multi-item Logic
    const fixedGoalList = document.getElementById('fixed_goal_list');
    const addFixedGoalBtn = document.getElementById('add_fixed_goal_btn');
    const hCertificationGoal = document.getElementById('h_certification_goal');

    function syncGoals() {
      const mode = document.getElementById('h_goal_mode').value;
      if (mode === 'fixed') {
        const items = Array.from(fixedGoalList.querySelectorAll('.goal-item-input')).map(input => input.value.trim()).filter(v => v !== "");
        hCertificationGoal.value = JSON.stringify(items);
      } else {
        const dailyGoals = {};
        const activeDays = [];
        ['월','화','수','목','금','토','일'].forEach(day => {
          const items = Array.from(document.getElementById(`daily_goal_list_${day}`).querySelectorAll('.goal-item-input')).map(input => input.value.trim()).filter(v => v !== "");
          if (items.length > 0) {
            dailyGoals[day] = items;
            activeDays.push(day);
          }
        });
        document.getElementById('h_daily_goals').value = JSON.stringify(dailyGoals);
        document.getElementById('h_days').value = JSON.stringify(activeDays);
        updateScheduleDots(activeDays);
      }
    }

    function updateScheduleDots(activeDays) {
      document.querySelectorAll('.day-opt').forEach(btn => {
        const day = btn.dataset.val;
        const isActive = activeDays.includes(day);
        btn.classList.toggle('selected-cat', isActive);
        btn.classList.toggle('unselected-opt', !isActive);
      });

      // Also update labels in Step 2 for visual feedback
      document.querySelectorAll('.day-label-box').forEach(box => {
        const day = box.dataset.dayName;
        const isActive = activeDays.includes(day);
        box.classList.toggle('bg-indigo-500/10', isActive);
        box.classList.toggle('border-indigo-500/40', isActive);
        box.classList.toggle('text-indigo-400', isActive);
        box.classList.toggle('bg-white/5', !isActive);
        box.classList.toggle('border-white/10', !isActive);
        box.classList.toggle('text-slate-500', !isActive);
      });
    }

    function addGoalItemRow(container, value = "") {
      const div = document.createElement('div');
      div.className = "flex items-center gap-2 animate-fade-in";
      div.innerHTML = `
        <div class="w-1.5 h-1.5 rounded-full bg-indigo-500 shrink-0"></div>
        <input type="text" value="${value}" placeholder="수행할 목표를 입력하세요" class="goal-item-input glass-input flex-1 p-3 text-sm focus:scale-[1.01]">
        <button type="button" class="remove-goal-btn p-2 text-slate-700 hover:text-red-400/60 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      `;
      div.querySelector('.remove-goal-btn').addEventListener('click', () => {
        div.remove();
        syncGoals();
      });
      div.querySelector('input').addEventListener('input', syncGoals);
      container.appendChild(div);
      div.querySelector('input').focus();
    }

    addFixedGoalBtn.addEventListener('click', () => addGoalItemRow(fixedGoalList));
    
    document.querySelectorAll('.add-daily-goal-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const day = btn.dataset.day;
        addGoalItemRow(document.getElementById(`daily_goal_list_${day}`));
      });
    });

    // Initial items
    addGoalItemRow(fixedGoalList, "예: 매일 물 1L 마시기");
    
    // Initialize one row per day for daily mode (hidden initially)
    ['월','화','수','목','금','토','일'].forEach(day => {
      addGoalItemRow(document.getElementById(`daily_goal_list_${day}`));
    });

    // Reset initial empty states for daily goals in sync
    syncGoals();

    handleSelect(document.querySelectorAll('.cat-opt'), 'h_category', 'selected-cat');

    // Bind smart scroll to all inputs and textareas
    document.querySelectorAll('input, textarea').forEach(el => {
      el.addEventListener('focus', () => smartScroll(el));
    });
    
    // Mission Goal Mode Toggle (Fixed vs Daily)
    handleSelect(document.querySelectorAll('.mode-opt'), 'h_goal_mode', 'selected-cat', (val) => {
      document.getElementById('goal_fixed').classList.toggle('hidden', val !== 'fixed');
      document.getElementById('goal_daily').classList.toggle('hidden', val !== 'daily');
      syncGoals();
    });

    // Thresholds
    document.getElementById('input_full_refund').addEventListener('input', (e) => {
      document.getElementById('h_full_refund').value = e.target.value;
    });
    document.getElementById('input_failure_tolerance').addEventListener('input', (e) => {
      document.getElementById('h_failure_tolerance').value = e.target.value;
    });

    handleSelect(document.querySelectorAll('.v-type-opt'), 'h_v_type', 'premium-selection');
    
    // Schedule Days
    document.querySelectorAll('.day-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.classList.toggle('selected-cat');
        btn.classList.toggle('unselected-opt');
        const days = Array.from(document.querySelectorAll('.day-opt.selected-cat')).map(b => b.dataset.val);
        document.getElementById('h_days').value = JSON.stringify(days);
        smartScroll(btn);
      });
    });

    // Entry / Admission
    document.querySelectorAll('.entry-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.entry-opt').forEach(b => b.className = "entry-opt p-6 rounded-[28px] border flex flex-col items-center gap-3 transition-all unselected-opt");
        btn.className = "entry-opt p-6 rounded-[28px] border flex flex-col items-center gap-3 transition-all premium-selection";
        document.getElementById('h_is_private').value = btn.dataset.val;
        document.getElementById('private_code_box').classList.toggle('hidden', btn.dataset.val === 'false');
        smartScroll(btn);
      });
    });

    document.querySelectorAll('.admission-opt').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.admission-opt').forEach(b => b.className = "admission-opt p-4 rounded-xl border font-black text-sm transition-all unselected-opt");
        btn.className = "admission-opt p-4 rounded-xl border font-black text-sm transition-all premium-selection";
        document.getElementById('h_admission').value = btn.dataset.val;
        smartScroll(btn);
      });
    });

    // Slider
    document.getElementById('max_slider').addEventListener('input', (e) => {
      document.getElementById('max_val').textContent = e.target.value + "명";
    });

    // Cost Toggle
    const costGuides = {
      free: "비용 없이 누구나 자유롭게 참여할 수 있는 챌린지에 적합합니다.",
      fee: "주최자의 노하우를 제공하고 수익을 창출하는 전문적인 챌린지에 권장합니다.",
      deposit: "보증금 방식은 참여자의 동기부여를 높이고 성실한 참여를 유도하기에 가장 좋습니다."
    };

    handleSelect(document.querySelectorAll('.cost-opt'), 'h_cost_type', 'selected-cat', (val) => {
      const amountInput = document.querySelector('input[name="challenge[amount]"]');
      if (val === 'free') {
        amountInput.value = 0;
        const feeInput = document.querySelector('input[name="challenge[participation_fee]"]');
        const penaltyInput = document.querySelector('input[name="challenge[penalty_per_failure]"]');
        if (feeInput) feeInput.value = 0;
        if (penaltyInput) penaltyInput.value = 0;
        document.getElementById('cost_amount_box').classList.add('hidden');
        document.getElementById('cost_bank_box').classList.add('hidden');
      } else {
        if (!amountInput.value || parseInt(amountInput.value) === 0) {
          amountInput.value = 10000;
        }
        document.getElementById('cost_amount_box').classList.remove('hidden');
        document.getElementById('cost_bank_box').classList.remove('hidden');
      }
      document.getElementById('deposit_options').classList.toggle('hidden', val !== 'deposit');
      document.getElementById('cost_guide_text').textContent = costGuides[val];
      
      const label = document.querySelector('#cost_amount_box label');
      if (val === 'fee') label.textContent = "Participation Fee (참가비)";
      if (val === 'deposit') label.textContent = "Deposit Amount (보증금)";
    });

    const toggleAddFee = document.getElementById('toggle_add_fee');
    const addFeeInput = document.getElementById('add_fee_input');
    toggleAddFee.addEventListener('click', () => {
      const active = toggleAddFee.classList.toggle('active');
      addFeeInput.classList.toggle('hidden', !active);
    });

    handleSelect(document.querySelectorAll('.bank-opt'), 'h_bank', 'selected-cat');

    // Toggles
    const setupToggle = (id, hiddenId) => {
      const el = document.getElementById(id);
      el.addEventListener('click', () => {
        const active = el.classList.toggle('active');
        document.getElementById(hiddenId).value = active;
      });
    };
    setupToggle('toggle_approval', 'h_requires_approval');
    setupToggle('toggle_reverify', 'h_reverify');

    // All Day Toggle Logic
    const alldayToggle = document.getElementById('toggle_allday');
    const timeRow = document.getElementById('time_inputs_row');
    const startTime = document.getElementById('v_start_time');
    const endTime = document.getElementById('v_end_time');

    alldayToggle.addEventListener('click', () => {
      const isAllDay = alldayToggle.classList.toggle('active');
      if (isAllDay) {
        startTime.value = "00:00";
        endTime.value = "23:59";
        timeRow.style.opacity = "0.4";
        timeRow.style.pointerEvents = "none";
      } else {
        timeRow.style.opacity = "1";
        timeRow.style.pointerEvents = "auto";
      }
    });

    // Participant Info Toggle
    const toggleParticipantInfo = document.getElementById('toggle_participant_info');
    const participantQuestionBox = document.getElementById('participant_question_box');
    toggleParticipantInfo.addEventListener('click', () => {
      const active = toggleParticipantInfo.classList.toggle('active');
      participantQuestionBox.classList.toggle('hidden', !active);
      document.getElementById('h_requires_msg').value = active;
    });

    // Rufa Only Toggle
    const toggleRufaOnly = document.getElementById('toggle_rufa_only');
    const btnRufaOnly = document.getElementById('btn_rufa_only');
    btnRufaOnly.addEventListener('click', () => {
      const active = toggleRufaOnly.classList.toggle('active');
      document.getElementById('h_rufa_only').value = active;
      
      if (active) {
        btnRufaOnly.classList.add('premium-selection');
        btnRufaOnly.classList.remove('bg-indigo-500/5', 'border-indigo-500/10');
      } else {
        btnRufaOnly.classList.remove('premium-selection');
        btnRufaOnly.classList.add('bg-indigo-500/5', 'border-indigo-500/10');
      }
    });

    // === Multiple Questions Logic ===
    function updateQuestionsJson() {
      if (!questionsHidden) return;
      const inputs = document.querySelectorAll('.question-input');
      const questions = Array.from(inputs)
        .map(input => input.value.trim())
        .filter(val => val !== "");
      questionsHidden.value = JSON.stringify(questions);
    }

    function createQuestionInput(value = "") {
      const div = document.createElement('div');
      div.className = "flex gap-2 items-start group";
      div.innerHTML = `
        <div class="flex-1">
          <input type="text" class="glass-input w-full p-4 text-sm focus:scale-[1.01] question-input bg-white/5 border border-white/10 rounded-xl" placeholder="질문을 입력해주세요 (예: 신청 동기가 무엇인가요?)" value="${value.replace(/"/g, '&quot;')}">
        </div>
        <button type="button" class="w-[50px] h-[50px] rounded-xl bg-white/5 border border-white/5 flex items-center justify-center text-slate-500 hover:text-rose-400 hover:bg-rose-500/10 transition-all remove-question-btn shrink-0 mt-0.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
        </button>
      `;
      
      div.querySelector('.remove-question-btn').addEventListener('click', () => {
        div.remove();
        updateQuestionsJson();
      });
      
      const input = div.querySelector('input');
      input.addEventListener('input', updateQuestionsJson);
      input.addEventListener('focus', () => smartScroll(input));
      
      return div;
    }

    if (addQuestionBtn) {
      addQuestionBtn.addEventListener('click', () => {
        const newQ = createQuestionInput();
        questionsList.appendChild(newQ);
        setTimeout(() => newQ.querySelector('input').focus(), 50);
        updateQuestionsJson();
      });
    }

    // Initial Questions Load
    if (questionsHidden) {
      try {
        const val = questionsHidden.value || "[]";
        const existing = JSON.parse(val);
        if (existing.length > 0) {
          existing.forEach(q => questionsList.appendChild(createQuestionInput(q)));
        } else {
           questionsList.appendChild(createQuestionInput(""));
        }
      } catch(e) {
        questionsList.appendChild(createQuestionInput(""));
      }
    }

    update();

    // Prevent accidental exit
    setTimeout(() => {
      const form = document.querySelector('form');
      if (form) {
        form.addEventListener('change', () => { isFormDirty = true; });
        form.addEventListener('input', () => { isFormDirty = true; });
        form.addEventListener('submit', () => { isFormDirty = false; });
        
        window.addEventListener('beforeunload', (e) => {
          if (isFormDirty) {
            e.preventDefault();
            e.returnValue = '';
          }
        });
        
        document.addEventListener('turbo:before-visit', (e) => {
          if (isFormDirty && document.body.contains(form)) {
             if (!confirm('작성 중인 내용이 저장되지 않았습니다. 정말 나가시겠습니까?')) {
               e.preventDefault();
             } else {
               isFormDirty = false;
             }
          }
        });
      }
    }, 500);
  })();
</script>
