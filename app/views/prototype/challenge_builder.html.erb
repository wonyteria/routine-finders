           <div class="p-6 bg-white/5 rounded-[32px] border border-white/5 space-y-5">
              <div class="flex items-center justify-between">
                <div>
                  <p class="text-[11px] font-black text-white">참여 신청 시 정보 받기</p>
                  <p class="text-[9px] font-bold text-slate-500 mt-0.5">참여 희망자에게 사전에 질문을 던집니다</p>
                </div>
                <div class="toggle-pill cursor-pointer" id="toggle_participant_info">
                  <div class="toggle-circle"></div>
                </div>
              </div>
              
              <div id="participant_question_box" class="hidden space-y-4 pt-2 border-t border-white/5">
                <label class="text-[10px] font-black text-slate-600 uppercase tracking-widest pl-1">Questions to Participants</label>
                
                <div id="questions_list" class="space-y-3">
                   <!-- Questions will be dynamically added here -->
                </div>

                <button type="button" id="add_question_btn" class="w-full py-4 rounded-2xl border-2 border-dashed border-white/10 text-slate-500 font-bold text-xs hover:border-indigo-500/40 hover:text-indigo-400 transition-all flex items-center justify-center gap-2 group">
